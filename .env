# ==============================
# Email Credentials
# (Use your Gmail and App Password. 
# Learn how to generate an App Password here: 
# https://support.google.com/accounts/answer/185833)
# ==============================
EMAIL_ADDRESS=YOUR_EMAIL_HERE@gmail.com
EMAIL_PASSWORD=YOUR_APP_PASSWORD_HERE

# ==============================
# API Keys
# (Get your free API keys from the links below)
# ==============================

# News API → https://newsapi.org/register
NEWS_API_KEY=YOUR_NEWS_API_KEY_HERE

# Cohere AI (for NLP/LLMs) → https://dashboard.cohere.com/api-keys
COHERE_API_KEY=YOUR_COHERE_API_KEY_HERE

# Groq Cloud (LLM inference accelerator) → https://console.groq.com/
GROQ_API_KEY=YOUR_GROQ_API_KEY_HERE

# OpenWeather (for weather data) → https://home.openweathermap.org/users/sign_up
OPENWEATHER_API_KEY=YOUR_OPENWEATHER_API_KEY_HERE

# Alpha Vantage (for financial market data) → https://www.alphavantage.co/support/#api-key
ALPHAVANTAGE_API_KEY=YOUR_ALPHAVANTAGE_API_KEY_HERE
